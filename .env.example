# Clarifai API Configuration
# Obtén tus credenciales en: https://clarifai.com/settings/security
CLARIFAI_API_KEY=your_clarifai_api_key_here
CLARIFAI_USER_ID=your_clarifai_user_id_here
CLARIFAI_APP_ID=your_clarifai_app_id_here

# Opcional: Especifica el modelo de Clarifai (por defecto: GPT-4)
# Ejemplos: GPT-4, gpt-4-turbo, claude-v2, llama2-70b-chat
CLARIFAI_MODEL_ID=GPT-4

# Opcional: Especifica la versión del modelo (deja vacío para usar la última)
CLARIFAI_MODEL_VERSION_ID=

# NOTA: ElevenLabs (Text-to-Speech) se accede a través de Clarifai
# La función generate-audio usa el modelo de ElevenLabs disponible en Clarifai
# Si tu integración de Clarifai para ElevenLabs lo requiere, puedes pasar además tu API key de ElevenLabs
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=SOYHLrjzK2X1ezoPC6cr
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
ELEVENLABS_STABILITY=0.5
ELEVENLABS_SIMILARITY_BOOST=0.5
ELEVENLABS_STYLE=0
ELEVENLABS_USE_SPEAKER_BOOST=true

# INSTRUCCIONES:
# 1. Copia este archivo como .env (sin .example)
# 2. Reemplaza los valores con tus credenciales reales de Clarifai
# 3. Nunca subas el archivo .env a Git (ya está en .gitignore)
